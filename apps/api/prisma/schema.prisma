generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
}

enum CustomerSegment {
  RETAIL
  WHOLESALE
  DISTRIBUTOR
}

enum OrderChannel {
  WEB
  SALES
  MARKETPLACE
  PHONE
}

enum OrderStatus {
  DRAFT
  PENDING_CONFIRMATION
  CONFIRMED
  WAITING_PAYMENT
  PAID
  PROCESSING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum InventoryMovementType {
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RESERVATION
  RESERVATION_RELEASE
  SALE
  RETURN
  TRANSFER_IN
  TRANSFER_OUT
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOID
}

enum PaymentStatus {
  UNPAID
  PENDING_VERIFICATION
  PAID
  FAILED
  EXPIRED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  EWALLET
}

enum ShipmentStatus {
  PENDING
  SCHEDULED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED_DELIVERY
  RETURNED_TO_WAREHOUSE
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum ReturnStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ITEM_RECEIVED
  REPLACEMENT_SENT
  REFUNDED
  CLOSED
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique @db.VarChar(255)
  name                String               @db.VarChar(150)
  passwordHash        String               @map("password_hash")
  status              UserStatus           @default(ACTIVE)
  refreshTokenHash    String?              @map("refresh_token_hash")
  lastLoginAt         DateTime?            @map("last_login_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")
  roles               UserRole[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  createdOrders       SalesOrder[]         @relation("OrderCreator")
  verifiedPayments    Payment[]            @relation("PaymentVerifier")
  complaints          Complaint[]          @relation("ComplaintCreator")
  complaintMessages   ComplaintMessage[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(50)
  name        String           @db.VarChar(100)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(100)
  description String?          @db.VarChar(255)
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  products    Product[]

  @@map("categories")
}

model Product {
  id            String              @id @default(uuid()) @db.Uuid
  sku           String              @unique @db.VarChar(50)
  name          String              @db.VarChar(150)
  description   String?
  categoryId    String              @map("category_id") @db.Uuid
  sellingPrice  Int                 @map("selling_price")
  purchasePrice Int?                @map("purchase_price")
  minimumStock  Int                 @default(0) @map("minimum_stock")
  imageUrl      String?             @map("image_url")
  isActive      Boolean             @default(true) @map("is_active")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")
  category      Category            @relation(fields: [categoryId], references: [id])
  prices        ProductPrice[]
  balances      InventoryBalance[]
  movements     InventoryMovement[]
  reservations  StockReservation[]
  orderItems    SalesOrderItem[]
  returnItems   ReturnItem[]

  @@index([name])
  @@index([categoryId, isActive])
  @@map("products")
}

model ProductPrice {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  price     Int
  validFrom DateTime @default(now()) @map("valid_from")
  changedBy String?  @map("changed_by") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, validFrom])
  @@map("product_prices")
}

model Customer {
  id           String            @id @default(uuid()) @db.Uuid
  code         String            @unique @db.VarChar(30)
  name         String            @db.VarChar(150)
  email        String?           @db.VarChar(255)
  phone        String            @db.VarChar(20)
  segment      CustomerSegment   @default(RETAIL)
  creditLimit  Int               @default(0) @map("credit_limit")
  loyaltyPoint Int               @default(0) @map("loyalty_point")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  deletedAt    DateTime?         @map("deleted_at")
  addresses    CustomerAddress[]
  orders       SalesOrder[]

  @@index([name])
  @@map("customers")
}

model CustomerAddress {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  label      String   @default("Utama") @db.VarChar(50)
  address    String
  city       String   @db.VarChar(100)
  province   String   @db.VarChar(100)
  postalCode String?  @map("postal_code") @db.VarChar(10)
  isPrimary  Boolean  @default(true) @map("is_primary")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model Warehouse {
  id           String              @id @default(uuid()) @db.Uuid
  code         String              @unique @db.VarChar(30)
  name         String              @db.VarChar(150)
  address      String
  city         String              @db.VarChar(100)
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  deletedAt    DateTime?           @map("deleted_at")
  balances     InventoryBalance[]
  movements    InventoryMovement[]
  reservations StockReservation[]
  orders       SalesOrder[]

  @@map("warehouses")
}

model InventoryBalance {
  id          String    @id @default(uuid()) @db.Uuid
  warehouseId String    @map("warehouse_id") @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  updatedAt   DateTime  @updatedAt @map("updated_at")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
  @@index([productId])
  @@map("inventory_balances")
}

model InventoryMovement {
  id           String                @id @default(uuid()) @db.Uuid
  warehouseId  String                @map("warehouse_id") @db.Uuid
  productId    String                @map("product_id") @db.Uuid
  type         InventoryMovementType
  quantity     Int
  balanceAfter Int                   @map("balance_after")
  reference    String?               @db.VarChar(100)
  reason       String?               @db.VarChar(250)
  actorId      String?               @map("actor_id") @db.Uuid
  createdAt    DateTime              @default(now()) @map("created_at")
  warehouse    Warehouse             @relation(fields: [warehouseId], references: [id])
  product      Product               @relation(fields: [productId], references: [id])

  @@index([warehouseId, productId, createdAt])
  @@map("inventory_movements")
}

model StockReservation {
  id           String     @id @default(uuid()) @db.Uuid
  salesOrderId String     @map("sales_order_id") @db.Uuid
  warehouseId  String     @map("warehouse_id") @db.Uuid
  productId    String     @map("product_id") @db.Uuid
  quantity     Int
  releasedAt   DateTime?  @map("released_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id])
  product      Product    @relation(fields: [productId], references: [id])

  @@index([salesOrderId])
  @@map("stock_reservations")
}

model SalesOrder {
  id             String             @id @default(uuid()) @db.Uuid
  orderNumber    String             @unique @map("order_number") @db.VarChar(30)
  customerId     String             @map("customer_id") @db.Uuid
  warehouseId    String             @map("warehouse_id") @db.Uuid
  createdById    String             @map("created_by_id") @db.Uuid
  channel        OrderChannel       @default(SALES)
  status         OrderStatus        @default(DRAFT)
  subtotal       Int
  discountAmount Int                @default(0) @map("discount_amount")
  taxAmount      Int                @default(0) @map("tax_amount")
  grandTotal     Int                @map("grand_total")
  notes          String?
  idempotencyKey String?            @unique @map("idempotency_key") @db.VarChar(100)
  confirmedAt    DateTime?          @map("confirmed_at")
  cancelledAt    DateTime?          @map("cancelled_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  customer       Customer           @relation(fields: [customerId], references: [id])
  warehouse      Warehouse          @relation(fields: [warehouseId], references: [id])
  createdBy      User               @relation("OrderCreator", fields: [createdById], references: [id])
  items          SalesOrderItem[]
  reservations   StockReservation[]
  invoice        Invoice?
  shipment       Shipment?
  complaints     Complaint[]
  returns        Return[]

  @@index([status, createdAt])
  @@index([customerId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String       @id @default(uuid()) @db.Uuid
  salesOrderId String       @map("sales_order_id") @db.Uuid
  productId    String       @map("product_id") @db.Uuid
  quantity     Int
  unitPrice    Int          @map("unit_price")
  subtotal     Int
  salesOrder   SalesOrder   @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
  returnItems  ReturnItem[]

  @@unique([salesOrderId, productId])
  @@map("sales_order_items")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @unique @map("invoice_number") @db.VarChar(30)
  salesOrderId  String        @unique @map("sales_order_id") @db.Uuid
  status        InvoiceStatus @default(ISSUED)
  amount        Int
  issuedAt      DateTime      @default(now()) @map("issued_at")
  dueAt         DateTime      @map("due_at")
  paidAt        DateTime?     @map("paid_at")
  salesOrder    SalesOrder    @relation(fields: [salesOrderId], references: [id])
  payments      Payment[]

  @@map("invoices")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  paymentNumber String        @unique @map("payment_number") @db.VarChar(30)
  invoiceId     String        @map("invoice_id") @db.Uuid
  amount        Int
  method        PaymentMethod
  status        PaymentStatus @default(PENDING_VERIFICATION)
  reference     String        @db.VarChar(100)
  proofUrl      String?       @map("proof_url")
  verifiedById  String?       @map("verified_by_id") @db.Uuid
  verifiedAt    DateTime?     @map("verified_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  verifiedBy    User?         @relation("PaymentVerifier", fields: [verifiedById], references: [id])

  @@index([invoiceId, status])
  @@map("payments")
}

model Shipment {
  id             String          @id @default(uuid()) @db.Uuid
  shipmentNumber String          @unique @map("shipment_number") @db.VarChar(30)
  salesOrderId   String          @unique @map("sales_order_id") @db.Uuid
  courierName    String          @map("courier_name") @db.VarChar(150)
  trackingNumber String          @unique @map("tracking_number") @db.VarChar(100)
  status         ShipmentStatus  @default(PENDING)
  scheduledAt    DateTime?       @map("scheduled_at")
  deliveredAt    DateTime?       @map("delivered_at")
  proofUrl       String?         @map("proof_url")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  salesOrder     SalesOrder      @relation(fields: [salesOrderId], references: [id])
  events         ShipmentEvent[]

  @@index([status, createdAt])
  @@map("shipments")
}

model ShipmentEvent {
  id         String         @id @default(uuid()) @db.Uuid
  shipmentId String         @map("shipment_id") @db.Uuid
  status     ShipmentStatus
  note       String?
  location   String?        @db.VarChar(150)
  createdAt  DateTime       @default(now()) @map("created_at")
  shipment   Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
  @@map("shipment_events")
}

model Complaint {
  id           String             @id @default(uuid()) @db.Uuid
  ticketNumber String             @unique @map("ticket_number") @db.VarChar(30)
  salesOrderId String             @map("sales_order_id") @db.Uuid
  createdById  String             @map("created_by_id") @db.Uuid
  subject      String             @db.VarChar(200)
  status       ComplaintStatus    @default(OPEN)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  salesOrder   SalesOrder         @relation(fields: [salesOrderId], references: [id])
  createdBy    User               @relation("ComplaintCreator", fields: [createdById], references: [id])
  messages     ComplaintMessage[]

  @@index([status, createdAt])
  @@map("complaints")
}

model ComplaintMessage {
  id          String    @id @default(uuid()) @db.Uuid
  complaintId String    @map("complaint_id") @db.Uuid
  senderId    String    @map("sender_id") @db.Uuid
  message     String
  createdAt   DateTime  @default(now()) @map("created_at")
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  sender      User      @relation(fields: [senderId], references: [id])

  @@index([complaintId, createdAt])
  @@map("complaint_messages")
}

model Return {
  id           String       @id @default(uuid()) @db.Uuid
  returnNumber String       @unique @map("return_number") @db.VarChar(30)
  salesOrderId String       @map("sales_order_id") @db.Uuid
  status       ReturnStatus @default(REQUESTED)
  reason       String
  resolution   String?      @db.VarChar(50)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  salesOrder   SalesOrder   @relation(fields: [salesOrderId], references: [id])
  items        ReturnItem[]

  @@index([status, createdAt])
  @@map("returns")
}

model ReturnItem {
  id               String         @id @default(uuid()) @db.Uuid
  returnId         String         @map("return_id") @db.Uuid
  salesOrderItemId String         @map("sales_order_item_id") @db.Uuid
  productId        String         @map("product_id") @db.Uuid
  quantity         Int
  reason           String
  return           Return         @relation(fields: [returnId], references: [id], onDelete: Cascade)
  salesOrderItem   SalesOrderItem @relation(fields: [salesOrderItemId], references: [id])
  product          Product        @relation(fields: [productId], references: [id])

  @@map("return_items")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @map("entity_id") @db.VarChar(100)
  metadata  Json?
  ipAddress String?  @map("ip_address") @db.VarChar(64)
  requestId String?  @map("request_id") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}
